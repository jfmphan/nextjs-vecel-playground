# Copy to .env and adjust. The Go API reads these from the environment.
# Local development works with the defaults below (a SQLite file under ./data),
# so you only strictly need to change things for production.

# --- Database -------------------------------------------------------------
# Local dev: a SQLite file (pure-Go driver, no setup, auto-migrated).
DATABASE_URL=file:./data/inventory.db?_pragma=busy_timeout(5000)&_pragma=journal_mode(WAL)

# Production: point at Turso (libSQL) instead, and set the auth token.
#   DATABASE_URL=libsql://<your-db>.turso.io
#   DATABASE_AUTH_TOKEN=<turso-token>
# DATABASE_AUTH_TOKEN=

# --- Auth -----------------------------------------------------------------
# The single shared password that gates the whole app.
APP_PASSWORD=changeme
# HMAC key used to sign session cookies — use a long random string in production.
SESSION_SECRET=please-change-this-to-a-long-random-string

# --- Misc -----------------------------------------------------------------
# Force migrations to run on startup against a remote DB. Defaults to running
# only for local file databases; remote DBs are migrated via `go run ./cmd/migrate`.
# AUTO_MIGRATE=1
